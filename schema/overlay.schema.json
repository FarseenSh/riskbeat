{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/FarseenSh/openrisk/schema/overlay.schema.json",
  "title": "OpenRisk community-correction overlay file (array of entries)",
  "type": "array",
  "items": { "$ref": "#/definitions/entry" },
  "definitions": {
    "entry": {
      "type": "object",
      "required": [
        "id",
        "protocol_slug",
        "feed_key",
        "field",
        "correction_type",
        "source_url",
        "source_date",
        "contributor",
        "date",
        "provenance_tag",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "protocol_slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "feed_key": { "type": "string" },
        "field": { "type": "string", "minLength": 1 },
        "original_value": { "type": "string" },
        "corrected_value": { "type": "string" },
        "correction_type": { "enum": ["add", "update", "flag", "deprecate"] },
        "flag": { "type": "string" },
        "flag_reason": { "type": "string" },
        "evidence_url": { "type": "string", "format": "uri" },
        "source_url": { "type": "string", "format": "uri" },
        "source_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "contributor": { "type": "string", "pattern": "^github:[A-Za-z0-9-]+$" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "provenance_tag": {
          "enum": ["onchain", "feed", "curated", "self-reported"]
        },
        "status": { "enum": ["open", "merged", "rejected", "superseded"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "correction_type": { "const": "flag" } }
          },
          "then": { "required": ["flag", "flag_reason", "evidence_url"] }
        },
        {
          "if": {
            "properties": { "correction_type": { "const": "update" } }
          },
          "then": { "required": ["original_value", "corrected_value"] }
        },
        {
          "if": {
            "properties": { "correction_type": { "const": "add" } }
          },
          "then": { "required": ["corrected_value"] }
        }
      ]
    }
  }
}
